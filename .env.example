# Swarms API
SWARMS_API_KEY=""
NEXT_PUBLIC_SWARMS_API_KEY=""

# Supabase (required for /login and /signup)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

SUPABASE_SERVICE_ROLE_KEY=""

# Optional — used to build absolute OAuth redirect URLs in non-browser contexts
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Stripe billing (Pro/Premium subscriptions)
# STRIPE_SECRET_KEY: your Stripe secret key (sk_live_… or sk_test_…)
# STRIPE_WEBHOOK_SECRET: signing secret for the /api/billing/webhook endpoint (whsec_…)
# STRIPE_PRICE_PRO / STRIPE_PRICE_PREMIUM: recurring Price IDs for each plan (price_…)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_PREMIUM=""
